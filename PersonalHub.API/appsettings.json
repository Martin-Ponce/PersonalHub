{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PersonalHub": "Server=ServerName;Initial Catalog=DBName;User Id=User;Password=Password;Trusted_Connection=False;Encrypt=False;TrustServerCertificate=True;",
    "Provider": "SqlServer"
  },
  "Logger": {
    "LogHttpRequests": false,
    "Sqlite": {
      "Path": "Logs\\Logs.db",
      "MinimumLevel": "Information"
    },
    "Main": {
      "MinimumLevel": "Error"
    }
  },
  "Jwt": {
    "Key": "keythatmustbeatleast32characterslong",
    "Issuer": "issuer",
    "Audience": "audience",
    "AccessDurationInMinutes": 60,
    "RefreshDurationInMinutes": 1440
  },
  "MaxCallsPerMinute": 100
}
